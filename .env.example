PORT=3000
DB_NAME=campuscart
MONGODB_URL=mongodb://localhost:27017
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
ACCESS_TOKEN_SECRET=replace_with_secure_access_token_secret
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=replace_with_secure_refresh_token_secret
REFRESH_TOKEN_EXPIRY=10d
STUDENT_OTP_EXPIRY_MINUTES=10
STUDENT_OTP_SECRET=replace_with_dedicated_otp_secret
STUDENT_OTP_RESEND_COOLDOWN_SECONDS=60
STUDENT_OTP_MAX_ATTEMPTS=5
STUDENT_OTP_LOCK_MINUTES=15
STUDENT_OTP_REQUEST_RATE_LIMIT_MAX=8
STUDENT_OTP_VERIFY_RATE_LIMIT_MAX=20
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=no-reply@yourdomain.com
CLOUDNARY_CLOUD_NAME=replace_with_cloud_name
CLOUDNARY_API_KEY=replace_with_cloudinary_api_key
CLOUDNARY_API_SECRET=replace_with_cloudinary_api_secret
PUBLIC_BASE_URL=https://your-backend.onrender.com
MICROSOFT_CLIENT_ID=replace_with_microsoft_client_id
MICROSOFT_CLIENT_SECRET=replace_with_microsoft_client_secret
MICROSOFT_TENANT_ID=replace_with_your_tenant_id
MICROSOFT_CALLBACK_URL=https://your-backend.onrender.com/auth/microsoft/callback
FRONTEND_URL=https://your-frontend.onrender.com
MICROSOFT_AUTH_SUCCESS_REDIRECT=https://your-frontend.onrender.com/
MICROSOFT_AUTH_FAILURE_REDIRECT=https://your-frontend.onrender.com/?authError=microsoft_oauth_failed
AUTH_COOKIE_SAMESITE=none
NODE_ENV=production
